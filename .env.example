APP_ENV=development
APP_SECRET=replace-this-in-production
DATABASE_URL=sqlite:///./heyu.db
AUTO_CREATE_SCHEMA=true
ABUSE_LIMITS_ENABLED=true
TRUSTED_PROXY_CIDRS=
ABUSE_BUCKET_RETENTION_SECONDS=86400
LOGIN_LIMIT_ATTEMPTS=10
LOGIN_LIMIT_WINDOW_SECONDS=300
BOOTSTRAP_LIMIT_ATTEMPTS=5
BOOTSTRAP_LIMIT_WINDOW_SECONDS=3600
INVITATION_CREATE_LIMIT_ATTEMPTS=30
INVITATION_CREATE_LIMIT_WINDOW_SECONDS=3600
INVITATION_INSPECT_LIMIT_ATTEMPTS=30
INVITATION_INSPECT_LIMIT_WINDOW_SECONDS=300
INVITATION_ACCEPT_LIMIT_ATTEMPTS=10
INVITATION_ACCEPT_LIMIT_WINDOW_SECONDS=300
DEMO_ACCESS_PROTECTION_ENABLED=false
DEMO_BASIC_AUTH_USERNAME=
DEMO_BASIC_AUTH_PASSWORD=
AI_PROVIDER=mock
AI_MODEL=deterministic-v1
# To use a model server that implements POST /v1/chat/completions:
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://your-provider.example/v1
# AI_MODEL=your-model-name
# AI_API_KEY=replace-with-your-own-key
# AI_TIMEOUT_SECONDS=45
MARKETING_CACHE_TTL_SECONDS=900
MARKETING_CACHE_MAX_ENTRIES=256
MARKETING_FALLBACK_TO_MOCK=true
CORS_ORIGINS=http://localhost:3000
